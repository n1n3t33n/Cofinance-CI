# Modèle de configuration — copiez ce fichier en « .env » et renseignez vos
# valeurs. Le vrai .env n'est JAMAIS versionné (il contient des secrets).
#
#   PowerShell : Copy-Item .env.example .env
#   Bash       : cp .env.example .env

# ─── Django ───────────────────────────────────────────────
# Générer une clé : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplacez-par-une-cle-secrete-longue-et-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de données PostgreSQL ───────────────────────────
DB_NAME=cofinance_ci
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe
DB_HOST=localhost
DB_PORT=5432

# ─── Email (production uniquement, DEBUG=False) ───────────
# En développement (DEBUG=True), les codes OTP s'affichent dans la console.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@cofinanceci.com
